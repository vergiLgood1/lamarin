{
  "name": "applyorbit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun  --bun next dev --turbopack",
    "dev:monitor": "bun scripts/dev-monitor.ts",
    "dev:monitor:node": "bun scripts/dev-monitor.ts --no-bun",
    "dev:monitor:noturbo": "bun scripts/dev-monitor.ts --no-turbo",
    "build": "bun --bun next build",
    "start": "bun --bun next start",
    "lint": "bun --bun eslint",
    "db:generate": "bun --bun drizzle-kit generate",
    "db:migrate": "bun --bun drizzle-kit migrate",
    "db:seed": "bun --bun src/db/seed.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:reset": "bun --bun drizzle-kit reset"
  },
